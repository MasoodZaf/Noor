{
    "cli": {
        "version": ">= 18.0.5",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": false
            }
        },
        "simulator": {
            "ios": {
                "simulator": true
            }
        },
        "dev-simulator": {
            "developmentClient": true,
            "ios": {
                "simulator": true,
                "buildConfiguration": "Debug"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "credentialsSource": "local"
            },
            "ios": {
                "buildConfiguration": "Release"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "buildConfiguration": "Release"
            }
        }
    },
    "submit": {
        "production": {}
    }
}