{
  "expo": {
    "name": "Falah",
    "slug": "falah-islamic-app",
    "scheme": "falah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.falah.islamic",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Falah uses the microphone to check your Quran recitation and provide tajweed feedback.",
        "NSSpeechRecognitionUsageDescription": "Falah uses speech recognition to analyse your Quran recitation.",
        "NSPhotoLibraryUsageDescription": "Falah uses the photo library to allow you to set a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0E32"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.falah.islamic",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A2CB0",
          "defaultChannel": "adhan"
        }
      ],
      "expo-asset",
      "expo-localization",
      "expo-speech-recognition"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fff3ce02-0c8b-4496-89f8-6cb267fd6683"
      }
    }
  }
}
